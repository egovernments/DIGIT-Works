{
  "key": "health-bill-transaction-report",
  "DataConfigs": {
    "serviceName": "hcm-payments",
    "version": "1.0.0",
    "baseKeyPath": "$.report",
    "mappings": [
      {
        "topic": "common-pdf-generation-3",
        "mappings": [
          {
            "direct": [


