                "localisation": { "required": true, "module": "hcm-payments" }
              },
              {
                "variable": "label_date",
                "value": { "path": "PDF_LABEL_TXN_REP_DATE" },
                "type": "label",
                "localisation": { "required": true, "module": "hcm-payments" }
              },
              {
                "variable": "label_bill_number",
                "value": { "path": "PDF_LABEL_TXN_REP_BILL_NUMBER" },
                "type": "label",
                "localisation": { "required": true, "module": "hcm-payments" }
              },
              {
                "variable": "label_mtn_transaction_id",
