                "type": "label",
                "localisation": { "required": true, "module": "hcm-payments" }
              },
              {
                "variable": "label_debit_amount",
                "value": { "path": "PDF_LABEL_TXN_REP_DEBIT_AMOUNT" },
                "type": "label",
                "localisation": { "required": true, "module": "hcm-payments" }
              },


              {
                "variable": "label_generated_time",
                "value": { "path": "PDF_LABEL_TXN_REP_GENERATED_TIME" },
                "type": "label",
                "localisation": { "required": true, "module": "hcm-payments" }
              },


              {
                "variable": "generatedTime",
                "value": { "path": "$.generatedTime" },
                "type": "date",
                "format": "DD/MM/YYYY HH:mm:ss z"
              },


              {
                "variable": "rows",
                "value": { "path": "$.rows" }
              }

            ]
          }
        ]
