{
  "key": "health-bill-transaction-report",
  "config": {
    "pageSize": "A4",
    "pageOrientation": "portrait",
    "defaultStyle": {
      "font": "Cambay"
    },
    "content": [
      {
        "style": "header",
        "alignment": "center",
        "fillColor": "#FCE5CD",
        "table": {
          "widths": ["100%"],
          "body": [
            [
              { "text": "{{reportTitle}}" }
            ]
          ]
        }
      },

      {
        "style": "table-style",
        "table": {
          "headerRows": 1,
          "widths": ["6%", "14%", "18%", "22%", "25%", "15%"],
          "body": [
            [
              { "text": "{{label_serial_no}}", "style": "table-header" },
              { "text": "{{label_date}}", "style": "table-header" },
              { "text": "{{label_bill_number}}", "style": "table-header" },
              { "text": "{{label_mtn_transaction_id}}", "style": "table-header" },
              { "text": "{{label_description}}", "style": "table-header" },
              { "text": "{{label_debit_amount}}", "style": "table-header" }
            ],

            "{{#rows}}[
            {\"text\":\"{{slNo}}\",\"style\":\"sl-no\"},
            {\"text\":\"{{date}}\",\"style\":\"table-content-text\"},
            {\"text\":\"{{billNumber}}\",\"style\":\"table-content-text\"},
            {\"text\":\"{{mtnTransactionId}}\",\"style\":\"table-content-text\"},
            {\"text\":\"{{description}}\",\"style\":\"table-content-text\"},
            {\"text\":\"{{debitAmount}}\",\"style\":\"table-content-number\"}
          ]{{/rows}}"
    ]
  }
},

{
"layout": "noBorders",
"margin": [0, 20, 0, 0],
"table": {
"widths": ["70%", "30%"],
"body": [
[
{ "text": "{{label_generated_time}}", "style": "reportEndText" },
{ "text": "{{generatedTime}}", "style": "reportEndText" }
]
]
}
}
],

"footer": "(function(currentPage, pageCount) { return { text: 'Page ' + currentPage + ' of ' + pageCount, alignment: 'right', margin: [0, 0, 20, 0] }; })",

"styles": {
"header": {
"fontSize": 16,
"bold": true
},
"table-style": {
"margin": [0, 10, 0, 0]
},
"table-header": {
"bold": true,
"fontSize": 10,
"color": "black",
"fillColor": "#c9daf8",
"alignment": "center"
},
"sl-no": {
"fillColor": "#d4d4d4",
"bold": true,
"alignment": "left",
"fontSize": 9
},
"table-content-text": {
"alignment": "left",
"fontSize": 9
},
"table-content-number": {
"alignment": "right",
"fontSize": 9
},
"reportEndText": {
"alignment": "left",
"fontSize": 10
}
}
}
}
