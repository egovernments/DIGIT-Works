              },
              {
                "label": "WORKS_BILL_TYPE",
                "jsonPath": "bill.businessService",
                "additionalCustomization": true
              },
              {
                "label": "CORE_COMMON_STATUS",
                "jsonPath": "bill.wfStatus",
                "additionalCustomization": true
              },
              {
                "label": "EXP_BILL_AMOUNT",
                "jsonPath": "bill.totalAmount",
                "headerAlign": "right",
                "additionalCustomization": true
              }
