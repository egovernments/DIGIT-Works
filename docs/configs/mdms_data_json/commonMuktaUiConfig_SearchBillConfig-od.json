            "showCheckBox": true,
            "resultsJsonPath": "bills",
            "enableColumnSort": true,
            "enableGlobalSearch": false,
            "checkBoxActionLabel": "ES_COMMON_GENERATE_PAYMENT_ADVICE",
            "showTableInstruction": "EXP_DOWNLOAD_BILL_INSTRUCTION"
